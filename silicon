function getFaseBadge(fase) {
  const f = (fase||'').toLowerCase();
  if (f.includes('negociação')) return `<span class="fase-badge fase-negociacao">${fase}</span>`;
  if (f.includes('fechamento') || f.includes('fechado')) return `<span class="fase-badge fase-fechamento">${fase}</span>`;
  if (f.includes('desenvolvimento')) return `<span class="fase-badge fase-desenvolvimento">${fase}</span>`;
  if (f.includes('potencial')) return `<span class="fase-badge fase-potencial">${fase}</span>`;
  if (f.includes('revisão')) return `<span class="fase-badge fase-revisao">${fase}</span>`;
  if (f.includes('abertura')) return `<span class="fase-badge fase-abertura">${fase}</span>`;
  if (f.includes('sem op') || f.includes('—') || f==='') return `<span class="fase-badge fase-sem">—</span>`;
  return `<span class="fase-badge fase-potencial">${fase}</span>`;
}
function getAreaTag(area) {
  const a = area.toLowerCase();
  if (a.includes('comercial') && !a.includes('eng')) return `<span class="area-tag area-comercial">${area}</span>`;
  if (a.includes('marketing')) return `<span class="area-tag area-marketing">${area}</span>`;
  if (a.includes('eng')) return `<span class="area-tag area-eng">${area}</span>`;
  if (a.includes('financeiro')) return `<span class="area-tag area-financeiro">${area}</span>`;
  return `<span class="area-tag area-comercial">${area}</span>`;
}
function getStatusTag(status) {
  const s = status.toLowerCase();
  if (s.includes('aguardando')) return `<span class="status-tag status-aguardando">Aguardando</span>`;
  if (s.includes('andamento')) return `<span class="status-tag status-andamento">Em andamento</span>`;
  if (s.includes('finalizado')) return `<span class="status-tag status-finalizado">Finalizado</span>`;
  if (s.includes('stanby') || s.includes('standby')) return `<span class="status-tag status-stanby">Stanby</span>`;
  return `<span class="status-tag status-aguardando">${status}</span>`;
}
function formatValor(v) {
  if (!v) return '<span class="valor-cell none">—</span>';
  if (v >= 10000000) return `<span class="valor-cell big">R$ ${(v/1000000).toFixed(1)}M</span>`;
  if (v >= 1000000) return `<span class="valor-cell">R$ ${(v/1000000).toFixed(2)}M</span>`;
  return `<span class="valor-cell">R$ ${v.toLocaleString('pt-BR',{minimumFractionDigits:0,maximumFractionDigits:0})}</span>`;
}
function getBUPill(bu) {
  const b = bu.toLowerCase();
  if (b==='industrial') return `<span class="bu-pill bu-industrial">Ind</span>`;
  if (b==='esportivo') return `<span class="bu-pill bu-esportivo">Esp</span>`;
  if (b==='cidades') return `<span class="bu-pill bu-cidades">Cid</span>`;
  return `<span class="bu-pill bu-industrial">${bu}</span>`;
}

function renderAcoes() {
  const container = document.getElementById('acoes-cards');
  const areaMap = {comercial:'comercial', marketing:'marketing', eng:'eng. comercial', financeiro:'financeiro'};

  let filtered = acoesData.filter(r => {
    const buMatch = activeBU === 'all' || r.bu.toLowerCase() === activeBU;
    const areaMatch = activeArea === 'all' || r.area.toLowerCase().includes(areaMap[activeArea]||'');
    return buMatch && areaMatch;
  });

  document.getElementById('acoes-count').textContent = filtered.length + ' ações';

  if (filtered.length === 0) {
    container.innerHTML = `<div class="empty-state">Nenhuma ação encontrada para este filtro.</div>`;
    return;
  }

  // Group by conta (preserving order)
  const groups = [];
  const keyMap = new Map();
  filtered.forEach(r => {
    const key = r.bu + '|' + r.conta;
    if (!keyMap.has(key)) {
      const g = {key, bu:r.bu, conta:r.conta, tipo:r.tipo, valor:r.valor, items:[]};
      keyMap.set(key, g);
      groups.push(g);
    }
    keyMap.get(key).items.push(r);
  });

  const fmtV = v => typeof v === 'number'
    ? `<span class="conta-group-valor${v>=10000000?' big':''}">${v>=1000000?'R$'+(v/1e6).toFixed(1)+'M':'R$'+(v/1000).toFixed(0)+'k'}</span>`
    : '';

  container.innerHTML = groups.map(g => {
    const cards = g.items.map(r => {
      const cardId = 'acao-' + r.n;
      const isDone = checkState[cardId] || false;
      const comments = commentState[cardId] || [];
      const commentCount = comments.length;
      const commentsHTML = comments.map((c, i) => `
        <div class="comment-item">
          <div class="comment-meta">
            <span class="comment-author">${c.author}</span>
            <span class="comment-date">${c.date}</span>
            <button class="comment-del" onclick="deleteComment('${cardId}', ${i})" title="Remover">✕</button>
          </div>
          <div class="comment-text">${c.text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>
        </div>`).join('');
      return `
      <div class="acao-card${isDone?' done':''}" id="card-${cardId}">
        <div style="display:flex;gap:12px;align-items:flex-start;width:100%">
          <button class="check-btn${isDone?' checked':''}" onclick="toggleCheck('${cardId}')" title="${isDone?'Desmarcar':'Marcar como concluído'}">
            <svg viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 5L4.5 8.5L11 1.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="acao-card-body" style="flex:1">
            <div class="acao-card-text">${r.acao.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>
            <div class="acao-card-meta">
              ${getAreaTag(r.area)}
              <span class="owner-pill">${r.owner}</span>
              ${getStatusTag(r.status)}
              <button class="comments-toggle" onclick="toggleComments('${cardId}')">
                <span class="ct-icon">💬</span>
                <span id="ct-label-${cardId}">${commentCount > 0 ? commentCount + ' comentário' + (commentCount>1?'s':'') : 'Comentar'}</span>
              </button>
            </div>
          </div>
          <div class="acao-card-side">
            <span class="acao-num">#${r.n}</span>
            <span class="prazo-badge"><span class="prazo-label">Prazo</span>${r.prazo}</span>
          </div>
        </div>
        <div class="comments-section" id="comments-${cardId}">
          <div class="comments-list" id="clist-${cardId}">${commentsHTML}</div>
          <div class="comment-name-row">
            <span class="comment-name-label">Seu nome:</span>
            <input class="comment-name-input" id="cname-${cardId}" type="text" placeholder="Ex: Pilato" value="${lastAuthor}">
          </div>
          <div class="comment-input-row">
            <textarea class="comment-input" id="cinput-${cardId}" placeholder="Adicionar comentário..." rows="2"></textarea>
            <button class="comment-send" onclick="addComment('${cardId}')">Enviar</button>
          </div>
        </div>
      </div>`;
    }).join('');

    return `<div class="conta-group">
      <div class="conta-group-header">
        ${getBUPill(g.bu)}
        <span class="conta-group-name">${g.conta}</span>
        <span class="tipo-tag ${g.tipo.toLowerCase()}">${g.tipo}</span>
        ${fmtV(g.valor)}
      </div>
      ${cards}
    </div>`;
  }).join('');
}

