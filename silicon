  cidades:   { pipeline:'R$ 87,6M',  pipelinesub:'BU Cidades', contas:'12', contassub:'12 clientes · 0 parceiros', planos:'11', planossub:'ações na BU', dez:'4', dezsub:'oportunidades grandes' },
};

function setFilter(bu) {
  activeBU = bu;
  // sidebar style
  ['all','industrial','esportivo','cidades'].forEach(b => {
    const el = document.getElementById('filter-'+b);
    el.classList.remove('active','all','ind','esp','cid');
  });
  const classMap = {all:'all',industrial:'ind',esportivo:'esp',cidades:'cid'};
  const el = document.getElementById('filter-'+bu);
  el.classList.add('active', classMap[bu]);

  // KPIs
  const d = kpiData[bu];
  document.getElementById('kpi-pipeline').textContent = d.pipeline;
  document.getElementById('kpi-pipeline-sub').textContent = d.pipelinesub;
  document.getElementById('kpi-contas').textContent = d.contas;
  document.getElementById('kpi-contas-sub').textContent = d.contassub;
  document.getElementById('kpi-planos').textContent = d.planos;
  document.getElementById('kpi-planos-sub').textContent = d.planossub;
  document.getElementById('kpi-10m').textContent = d.dez;
  document.getElementById('kpi-10m-sub').textContent = d.dezsub;

  // pipeline bar
  const rows = document.querySelectorAll('.p-bar-row');
  rows.forEach(r => {
    if (bu === 'all') { r.style.opacity = '1'; }
    else { r.style.opacity = r.dataset.bu === bu ? '1' : '0.25'; }
  });

  renderAcoes();
  calcPipelineByArea(bu);
  renderDiagArea(bu);
  renderDiagFaixa(bu);
}

function setArea(area) {
  activeArea = area;
  ['all','comercial','marketing','eng','financeiro'].forEach(a => {
    document.getElementById('area-'+a).classList.remove('active');
  });
  document.getElementById('area-'+area).classList.add('active');
  renderAcoes();
}

function setTab(tab) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  event.target.classList.add('active');
}

