function toggleCheck(cardId) {
  checkState[cardId] = !checkState[cardId];
  try { localStorage.setItem('silicon_pr03_checks', JSON.stringify(checkState)); } catch(e) {}
  const card = document.getElementById('card-' + cardId);
  const btn = card ? card.querySelector('.check-btn') : null;
  if (card) card.classList.toggle('done', checkState[cardId]);
  if (btn) {
    btn.classList.toggle('checked', checkState[cardId]);
    btn.title = checkState[cardId] ? 'Desmarcar' : 'Marcar como concluído';
  }
}

function toggleComments(cardId) {
  const section = document.getElementById('comments-' + cardId);
  if (!section) return;
  section.classList.toggle('open');
  if (section.classList.contains('open')) {
    const input = document.getElementById('cinput-' + cardId);
    if (input) setTimeout(() => input.focus(), 260);
  }
}

function addComment(cardId) {
  const input = document.getElementById('cinput-' + cardId);
  const nameInput = document.getElementById('cname-' + cardId);
  if (!input) return;
  const text = input.value.trim();
  if (!text) return;
  const author = (nameInput && nameInput.value.trim()) || 'Anônimo';
  lastAuthor = author;
  try { localStorage.setItem('silicon_pr03_author', author); } catch(e) {}
  if (!commentState[cardId]) commentState[cardId] = [];
  const now = new Date();
  const date = now.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'}) + ' ' + now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
  commentState[cardId].push({ author, text, date });
  try { localStorage.setItem('silicon_pr03_comments', JSON.stringify(commentState)); } catch(e) {}
  input.value = '';
  // Update comment list
  const list = document.getElementById('clist-' + cardId);
  if (list) {
    const c = commentState[cardId][commentState[cardId].length - 1];
    const idx = commentState[cardId].length - 1;
    list.insertAdjacentHTML('beforeend', `
      <div class="comment-item">
        <div class="comment-meta">
          <span class="comment-author">${c.author}</span>
          <span class="comment-date">${c.date}</span>
          <button class="comment-del" onclick="deleteComment('${cardId}', ${idx})" title="Remover">✕</button>
        </div>
        <div class="comment-text">${c.text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>
      </div>`);
  }
  updateCommentToggle(cardId);
}

function deleteComment(cardId, idx) {
  if (!commentState[cardId]) return;
  commentState[cardId].splice(idx, 1);
  try { localStorage.setItem('silicon_pr03_comments', JSON.stringify(commentState)); } catch(e) {}
  // Re-render comment list
  const list = document.getElementById('clist-' + cardId);
  if (list) {
    list.innerHTML = commentState[cardId].map((c, i) => `
      <div class="comment-item">
        <div class="comment-meta">
          <span class="comment-author">${c.author}</span>
          <span class="comment-date">${c.date}</span>
          <button class="comment-del" onclick="deleteComment('${cardId}', ${i})" title="Remover">✕</button>
        </div>
        <div class="comment-text">${c.text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>
      </div>`).join('');
  }
  updateCommentToggle(cardId);
}

function updateCommentToggle(cardId) {
  const label = document.getElementById('ct-label-' + cardId);
  if (!label) return;
  const count = (commentState[cardId] || []).length;
  label.textContent = count > 0 ? count + ' comentário' + (count > 1 ? 's' : '') : 'Comentar';
}

