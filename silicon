// ── DIAGNÓSTICO DINÂMICO ──
const fmt = v => v >= 1000000 ? 'R$'+(v/1000000).toFixed(1)+'M' : 'R$'+(v/1000).toFixed(0)+'k';

function faixaContas(buKey, minVal, maxVal) {
  const seen = new Set();
  return acoesData.filter(r => {
    if (buKey !== 'all' && r.bu.toLowerCase() !== buKey) return false;
    const key = r.bu+'|'+r.conta;
    if (seen.has(key)) return false;
    seen.add(key);
    return typeof r.valor === 'number' && r.valor >= minVal && r.valor < maxVal;
  });
}
function semValorContas(buKey) {
  const seen = new Set();
  return acoesData.filter(r => {
    if (buKey !== 'all' && r.bu.toLowerCase() !== buKey) return false;
    const key = r.bu+'|'+r.conta;
    if (seen.has(key)) return false;
    seen.add(key);
    return typeof r.valor !== 'number' || r.valor === null;
  });
}

function renderDiagFaixa(bu) {
  const buList = ['industrial','esportivo','cidades'];
  const buLabel = {industrial:'Ind', esportivo:'Esp', cidades:'Cid'};
  const buColor = {industrial:'var(--ind)', esportivo:'var(--esp)', cidades:'var(--cid)'};

  const colHeaders = bu === 'all'
    ? buList.map(b=>`<div class="diag-val ${b==='industrial'?'ind':b==='esportivo'?'esp':'cid'}" style="font-size:9px;font-weight:700;letter-spacing:0.06em">${buLabel[b]}</div>`).join('')
    : `<div class="diag-val" style="color:${buColor[bu]||'var(--accent)'};font-size:9px;font-weight:700">${bu.charAt(0).toUpperCase()+bu.slice(1)}</div>`;

  function makeRow(label, minVal, maxVal) {
    const list = faixaContas(bu, minVal, maxVal);
    const soma = list.reduce((s,r)=>s+r.valor,0);
    if (bu !== 'all') {
      return `<div class="diag-row">
        <div class="diag-row-label">${label}</div>
        <div class="diag-val total">${list.length||'—'}</div>
        <div class="diag-val" style="color:${buColor[bu]};font-family:'DM Mono',monospace;font-size:10px;min-width:60px;text-align:right">${list.length?fmt(soma):'—'}</div>
      </div>`;
    }
    const cols = buList.map(b=>{
      const n = faixaContas(b,minVal,maxVal).length;
      return `<div class="diag-val ${b==='industrial'?'ind':b==='esportivo'?'esp':'cid'}">${n||'—'}</div>`;
    }).join('');
    return `<div class="diag-row">
      <div class="diag-row-label">${label}</div>
      <div class="diag-val total">${faixaContas('all',minVal,maxVal).length||'—'}</div>
      ${cols}
    </div>`;
  }

  function makeSemRow() {
    const n = semValorContas(bu).length;
    if (bu !== 'all') {
      return `<div class="diag-row">
        <div class="diag-row-label" style="color:var(--orange)">Valor não mapeado</div>
        <div class="diag-val total">${n||'—'}</div>
        <div class="diag-val muted" style="color:var(--muted);font-size:10px;min-width:60px;text-align:right">${n} conta${n!==1?'s':''}</div>
      </div>`;
    }
    const cols = buList.map(b=>{
      const x = semValorContas(b).length;
      return `<div class="diag-val ${b==='industrial'?'ind':b==='esportivo'?'esp':'cid'} muted">${x||'—'}</div>`;
    }).join('');
    return `<div class="diag-row">
      <div class="diag-row-label" style="color:var(--orange)">Valor não mapeado</div>
      <div class="diag-val total">${semValorContas('all').length}</div>
      ${cols}
    </div>`;
  }

  const totalMapeado = (()=>{
    const seen = new Set();
    return acoesData.filter(r=>{
      if (bu!=='all' && r.bu.toLowerCase()!==bu) return false;
      const key=r.bu+'|'+r.conta;
      if(seen.has(key)) return false;
      seen.add(key);
      return typeof r.valor==='number';
    }).reduce((s,r)=>s+r.valor,0);
  })();

  document.getElementById('diag-faixa-head').textContent = 'Pipeline por Faixa de Valor';
  document.getElementById('diag-faixa-content').innerHTML = `
    <div class="diag-row" style="padding-bottom:6px;border-bottom:1px solid var(--border2)">
      <div class="diag-row-label" style="font-size:9px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:0.08em">Faixa</div>
      <div class="diag-val" style="font-size:9px;color:var(--muted);font-weight:600">Qtd</div>
      ${colHeaders}
    </div>
    <div class="diag-row">
      <div class="diag-row-label highlight">Valor total mapeado</div>
      <div class="diag-val money" style="font-size:11px">${fmt(totalMapeado)}</div>
    </div>
    ${makeRow('Acima de R$ 10M', 10000000, Infinity)}
    ${makeRow('Entre R$ 1M–10M', 1000000, 10000000)}
    ${makeRow('Abaixo de R$ 1M', 0, 1000000)}
    ${makeSemRow()}
  `;
}

function renderDiagArea(bu) {
  const buList = ['industrial','esportivo','cidades'];
  const buLabel = {industrial:'Ind', esportivo:'Esp', cidades:'Cid'};
  const buColor = {industrial:'var(--ind)', esportivo:'var(--esp)', cidades:'var(--cid)'};
  const areas = ['Comercial','Marketing','Eng. Comercial','Financeiro','RH','Operações','Enablement'];

  const countArea = (buKey, area) => acoesData.filter(r =>
    (buKey==='all'||r.bu.toLowerCase()===buKey) && r.area.toLowerCase().includes(area.toLowerCase())
  ).length;

  const totalAll = bu==='all' ? acoesData.length : acoesData.filter(r=>r.bu.toLowerCase()===bu).length;

  const colHeaders = bu === 'all'
    ? buList.map(b=>`<div class="diag-val ${b==='industrial'?'ind':b==='esportivo'?'esp':'cid'}" style="font-size:9px;font-weight:700;letter-spacing:0.06em">${buLabel[b]}</div>`).join('')
    : '';

  const rows = areas.map(a => {
    if (bu !== 'all') {
      const n = countArea(bu, a);
      return `<div class="diag-row"><div class="diag-row-label"${!n?' style="color:var(--muted)"':''}>${a}</div><div class="diag-val total"${!n?' style="color:var(--muted)"':''}>${n}</div></div>`;
    }
    const total = countArea('all', a);
    const cols = buList.map(b=>{
      const n = countArea(b,a);
      return `<div class="diag-val ${b==='industrial'?'ind':b==='esportivo'?'esp':'cid'}"${!n?' style="opacity:0.35"':''}>${n||'0'}</div>`;
    }).join('');
    return `<div class="diag-row"><div class="diag-row-label"${!total?' style="color:var(--muted)"':''}>${a}</div><div class="diag-val total"${!total?' style="color:var(--muted)"':''}>${total}</div>${cols}</div>`;
  }).join('');

  const totalCols = bu==='all'
    ? buList.map(b=>`<div class="diag-val ${b==='industrial'?'ind':b==='esportivo'?'esp':'cid'}">${acoesData.filter(r=>r.bu.toLowerCase()===b).length}</div>`).join('')
    : '';

  document.getElementById('diag-area-head').textContent = 'Distribuição por Área';
  document.getElementById('diag-area-content').innerHTML = `
    <div class="diag-row" style="padding-bottom:6px;border-bottom:1px solid var(--border2)">
      <div class="diag-row-label" style="font-size:9px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:0.08em">Área</div>
      <div class="diag-val" style="font-size:9px;color:var(--muted);font-weight:600">Total</div>
      ${colHeaders}
    </div>
    <div class="diag-row"><div class="diag-row-label highlight">Total de planos</div><div class="diag-val total">${totalAll}</div>${totalCols}</div>
    ${rows}
  `;
}



// Para cada área, somamos o valorRef (valor da conta na primeira linha que o registra)
// das ações que pertencem à BU ativa. Isso evita dupla contagem entre ações da mesma conta.
function calcPipelineByArea(bu) {
  const areaKeys = ['all','comercial','marketing','eng','financeiro'];
  const areaMatch = {comercial:'comercial', marketing:'marketing', eng:'eng. comercial', financeiro:'financeiro'};

  areaKeys.forEach(aKey => {
    const filtered = acoesData.filter(r => {
      const buMatch = bu === 'all' || r.bu.toLowerCase() === bu;
      const aMatch = aKey === 'all' || r.area.toLowerCase().includes(areaMatch[aKey]||'');
      return buMatch && aMatch && typeof r.valorRef === 'number';
    });
    const total = filtered.reduce((s, r) => s + r.valorRef, 0);
    const el = document.getElementById('apipe-' + aKey);
    if (el) el.textContent = total > 0 ? fmtPipe(total) : '';
  });
}

function fmtPipe(v) {
  if (v >= 1000000) return 'R$ ' + (v/1000000).toFixed(1) + 'M em oport.';
  if (v >= 1000) return 'R$ ' + (v/1000).toFixed(0) + 'k em oport.';
  return 'R$ ' + v.toLocaleString('pt-BR');
}
