<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pipeline Review — Silicon</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Sora:wght@300;400;500;600;700&display=swap');

  :root {
    --bg: #0a0c0f;
    --surface: #111318;
    --surface2: #181c23;
    --border: #1f2530;
    --border2: #2a3040;
    --text: #e8ecf2;
    --muted: #6b7585;
    --accent: #00c2ff;
    --accent2: #0084b4;
    --ind: #3b82f6;
    --esp: #f59e0b;
    --cid: #10b981;
    --all-color: #a78bfa;
    --green: #22c55e;
    --red: #ef4444;
    --orange: #f97316;
    --yellow: #eab308;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Sora', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── HEADER ── */
  header {
    padding: 18px 28px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .logo { display: flex; align-items: center; gap: 10px; }
  .logo-mark {
    width: 32px; height: 32px;
    background: var(--accent);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 13px; color: #000;
  }
  .logo-text { font-size: 14px; font-weight: 600; color: var(--text); }
  .logo-sub { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; }
  .header-meta {
    text-align: right;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    line-height: 1.6;
  }
  .header-meta strong { color: var(--accent); }

  /* ── LAYOUT ── */
  .layout {
    display: flex;
    flex: 1;
  }

  /* ── SIDEBAR FILTER ── */
  aside {
    width: 180px;
    min-width: 180px;
    border-right: 1px solid var(--border);
    background: var(--surface);
    padding: 24px 0;
    position: sticky;
    top: 61px;
    height: calc(100vh - 61px);
    overflow-y: auto;
  }
  .filter-label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0 16px 10px;
  }
  .filter-opt {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    cursor: pointer;
    border-left: 3px solid transparent;
    transition: all 0.15s;
    font-size: 13px;
    font-weight: 400;
    color: var(--muted);
    user-select: none;
  }
  .filter-opt:hover { background: var(--surface2); color: var(--text); }
  .filter-opt.active {
    color: var(--text);
    font-weight: 600;
    background: var(--surface2);
  }
  .filter-opt.active.all { border-left-color: var(--all-color); color: var(--all-color); }
  .filter-opt.active.ind { border-left-color: var(--ind); color: var(--ind); }
  .filter-opt.active.esp { border-left-color: var(--esp); color: var(--esp); }
  .filter-opt.active.cid { border-left-color: var(--cid); color: var(--cid); }
  .bu-dot {
    width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
  }
  .filter-count {
    margin-left: auto;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    background: var(--border2);
    padding: 2px 6px;
    border-radius: 10px;
    color: var(--muted);
  }

  aside .divider {
    height: 1px; background: var(--border); margin: 16px 0;
  }
  .sidebar-section { padding: 0 16px 8px; }
  .sidebar-section .filter-label { padding: 0 0 8px; }
  .area-item { display: flex; align-items: flex-start; flex-direction: column; gap: 2px; padding: 7px 0; font-size: 12px; color: var(--muted); cursor: pointer; transition: color 0.15s; }
  .area-item-row { display: flex; align-items: center; gap: 8px; width: 100%; }
  .area-item:hover { color: var(--text); }
  .area-item.active { color: var(--text); font-weight: 500; }
  .area-item .area-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--border2); flex-shrink: 0; }
  .area-item.active .area-dot { background: var(--accent); }
  .area-pipeline {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    color: var(--accent);
    opacity: 0.8;
    padding-left: 14px;
    min-height: 12px;
  }

  /* ── MAIN ── */
  main {
    flex: 1;
    padding: 24px 28px;
    overflow-y: auto;
  }

  /* ── TABS ── */
  .tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0;
  }
  .tab {
    padding: 8px 16px 10px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    color: var(--muted);
    transition: all 0.15s;
    letter-spacing: 0.02em;
  }
  .tab:hover { color: var(--text); }
  .tab.active { color: var(--accent); border-bottom-color: var(--accent); }

  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* ── KPI CARDS ── */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
    margin-bottom: 24px;
  }
  .kpi {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px 18px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .kpi:hover { border-color: var(--border2); }
  .kpi::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
  }
  .kpi.blue::before { background: var(--ind); }
  .kpi.amber::before { background: var(--esp); }
  .kpi.green::before { background: var(--cid); }
  .kpi.purple::before { background: var(--all-color); }
  .kpi.cyan::before { background: var(--accent); }
  .kpi-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 8px; }
  .kpi-value { font-size: 26px; font-weight: 700; line-height: 1; font-family: 'DM Mono', monospace; }
  .kpi-value.small { font-size: 18px; }
  .kpi-sub { font-size: 10px; color: var(--muted); margin-top: 6px; font-family: 'DM Mono', monospace; }
  .kpi-value.ind { color: var(--ind); }
  .kpi-value.esp { color: var(--esp); }
  .kpi-value.cid { color: var(--cid); }
  .kpi-value.accent { color: var(--accent); }
  .kpi-value.all { color: var(--all-color); }

  /* ── SECTION HEADER ── */
  .section-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    margin-top: 28px;
  }
  .section-head:first-of-type { margin-top: 0; }
  .section-title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }
  .section-line { flex: 1; height: 1px; background: var(--border); }
  .section-badge {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 10px;
    background: var(--border);
    color: var(--muted);
  }

  /* ── DIAGNÓSTICO TABLE ── */
  .diag-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 8px;
  }
  .diag-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }
  .diag-head {
    padding: 10px 16px;
    background: var(--surface2);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    border-bottom: 1px solid var(--border);
  }
  .diag-row {
    display: flex;
    align-items: center;
    padding: 9px 16px;
    border-bottom: 1px solid var(--border);
    gap: 12px;
    font-size: 12px;
    transition: background 0.1s;
  }
  .diag-row:last-child { border-bottom: none; }
  .diag-row:hover { background: var(--surface2); }
  .diag-row-label { flex: 1; color: var(--muted); }
  .diag-row-label.highlight { color: var(--text); font-weight: 500; }
  .diag-val {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    min-width: 52px;
    text-align: right;
    font-weight: 500;
  }
  .diag-val.total { color: var(--text); }
  .diag-val.ind { color: var(--ind); }
  .diag-val.esp { color: var(--esp); }
  .diag-val.cid { color: var(--cid); }
  .diag-val.muted { color: var(--muted); }
  .diag-val.money { color: var(--accent); }

  /* ── AÇÕES TABLE ── */
  .acoes-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    background: var(--surface);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .acoes-table th {
    padding: 9px 12px;
    text-align: left;
    background: var(--surface2);
    color: var(--muted);
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  .acoes-table td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
    line-height: 1.5;
  }
  .acoes-table tr:last-child td { border-bottom: none; }
  .acoes-table tr:hover td { background: #13171e; }
  .hidden { display: none !important; }

  .conta-name { font-weight: 600; color: var(--text); }
  .tipo-tag {
    font-size: 9px; font-weight: 600; text-transform: uppercase;
    padding: 2px 7px; border-radius: 4px; letter-spacing: 0.06em;
    display: inline-block; margin-top: 3px;
  }
  .tipo-tag.cliente { background: rgba(59,130,246,0.15); color: #7db4f8; }
  .tipo-tag.parceiro { background: rgba(245,158,11,0.15); color: #fbbf24; }

  .fase-badge {
    font-size: 9px; font-weight: 500;
    padding: 3px 8px; border-radius: 4px;
    white-space: nowrap; display: inline-block;
  }
  .fase-negociacao { background: rgba(0,194,255,0.12); color: var(--accent); }
  .fase-fechamento { background: rgba(34,197,94,0.12); color: #4ade80; }
  .fase-desenvolvimento { background: rgba(167,139,250,0.12); color: #c4b5fd; }
  .fase-potencial { background: rgba(107,117,133,0.15); color: var(--muted); }
  .fase-revisao { background: rgba(249,115,22,0.12); color: #fb923c; }
  .fase-abertura { background: rgba(16,185,129,0.12); color: #34d399; }
  .fase-sem { background: rgba(107,117,133,0.1); color: #4b5563; }

  .area-tag {
    font-size: 9px; font-weight: 600; padding: 2px 7px;
    border-radius: 4px; text-transform: uppercase; letter-spacing: 0.04em;
    display: inline-block;
  }
  .area-comercial { background: rgba(59,130,246,0.12); color: #60a5fa; }
  .area-marketing { background: rgba(167,139,250,0.12); color: #a78bfa; }
  .area-eng { background: rgba(245,158,11,0.12); color: #fbbf24; }
  .area-financeiro { background: rgba(16,185,129,0.12); color: #34d399; }

  .status-tag {
    font-size: 9px; font-weight: 600; padding: 2px 7px;
    border-radius: 4px; display: inline-block;
  }
  .status-aguardando { background: rgba(107,117,133,0.15); color: var(--muted); }
  .status-andamento { background: rgba(34,197,94,0.12); color: #4ade80; }
  .status-finalizado { background: rgba(0,194,255,0.12); color: var(--accent); }
  .status-stanby { background: rgba(249,115,22,0.1); color: #fb923c; }

  .bu-pill {
    font-size: 9px; font-weight: 700; padding: 2px 7px;
    border-radius: 4px; text-transform: uppercase; letter-spacing: 0.06em;
    display: inline-block;
  }
  .bu-industrial { background: rgba(59,130,246,0.15); color: #7db4f8; }
  .bu-esportivo { background: rgba(245,158,11,0.15); color: #fbbf24; }
  .bu-cidades { background: rgba(16,185,129,0.15); color: #34d399; }

  .valor-cell {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    white-space: nowrap;
    color: var(--accent);
    font-weight: 500;
  }
  .valor-cell.big { color: #f472b6; }
  .valor-cell.none { color: var(--muted); font-style: italic; font-size: 10px; }

  .prazo-cell { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); white-space: nowrap; }
  .prazo-cell.overdue { color: var(--red); }
  .prazo-cell.soon { color: var(--yellow); }

  .acao-text { color: #c9d1dc; max-width: 320px; line-height: 1.5; }
  .owner-cell { color: var(--text); font-weight: 500; white-space: nowrap; font-size: 11px; }

  /* ── GESTÃO GRID ── */
  .gestao-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 12px;
  }
  .gestao-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    transition: border-color 0.2s;
  }
  .gestao-card:hover { border-color: var(--border2); }
  .gestao-cat {
    font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
    padding: 2px 7px; border-radius: 4px; display: inline-block; margin-bottom: 10px;
  }
  .cat-inovacao { background: rgba(167,139,250,0.12); color: #c4b5fd; }
  .cat-outros { background: rgba(107,117,133,0.15); color: var(--muted); }
  .cat-contas { background: rgba(0,194,255,0.12); color: var(--accent); }
  .gestao-plano { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 6px; line-height: 1.4; }
  .gestao-meta { font-size: 11px; color: var(--muted); display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }

  /* ── MONITORAMENTO ── */
  .monitor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }
  .monitor-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
  }
  .monitor-area { font-size: 12px; font-weight: 600; color: var(--text); margin-bottom: 10px; }
  .monitor-bar-wrap { height: 5px; background: var(--border2); border-radius: 3px; margin-bottom: 10px; overflow: hidden; }
  .monitor-bar { height: 100%; border-radius: 3px; background: var(--accent); transition: width 0.6s ease; }
  .monitor-stats { display: flex; gap: 12px; font-size: 10px; font-family: 'DM Mono', monospace; }
  .monitor-stat { display: flex; flex-direction: column; gap: 2px; }
  .monitor-stat-val { font-size: 16px; font-weight: 700; color: var(--text); }
  .monitor-stat-label { color: var(--muted); font-size: 9px; }
  .monitor-stat-val.green { color: var(--green); }
  .monitor-stat-val.amber { color: var(--yellow); }

  /* ── PIPELINE BAR ── */
  .pipeline-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 18px 20px;
    margin-bottom: 16px;
  }
  .pipeline-title { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 14px; }
  .pipeline-bars { display: flex; flex-direction: column; gap: 10px; }
  .p-bar-row { display: flex; align-items: center; gap: 12px; }
  .p-bar-label { font-size: 12px; color: var(--muted); width: 90px; flex-shrink: 0; }
  .p-bar-track { flex: 1; height: 8px; background: var(--border2); border-radius: 4px; overflow: hidden; }
  .p-bar-fill { height: 100%; border-radius: 4px; transition: width 0.8s ease; }
  .p-bar-val { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text); min-width: 100px; text-align: right; }

  .empty-state {
    text-align: center;
    padding: 40px;
    color: var(--muted);
    font-size: 13px;
  }

  /* ── ACTION CARDS ── */
  .conta-group { margin-bottom: 16px; border-radius: 10px; overflow: hidden; border: 1px solid var(--border); }
  .conta-group-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 16px;
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
  }
  .conta-group-name { font-size: 13px; font-weight: 700; color: var(--text); flex: 1; }
  .conta-group-valor {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
  }
  .conta-group-valor.big { color: #f472b6; }

  .acao-card {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 14px 18px;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: background 0.12s;
  }
  .acao-card:first-of-type { border-top: none; }
  .acao-card:hover { background: #13171e; }
  .acao-card-body { display: flex; flex-direction: column; gap: 10px; }

  .acao-card-text {
    font-size: 12.5px;
    color: #c4cdd9;
    line-height: 1.7;
    white-space: pre-line;
  }
  .acao-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .owner-pill {
    font-size: 10px;
    font-weight: 500;
    color: var(--muted);
    background: var(--border);
    padding: 2px 8px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .owner-pill::before {
    content: '';
    display: inline-block;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--accent);
  }

  .acao-card-side {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    gap: 8px;
    min-width: 80px;
    flex-shrink: 0;
  }
  .acao-num {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    background: var(--border);
    padding: 2px 7px;
    border-radius: 4px;
  }
  .prazo-badge {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    white-space: nowrap;
    text-align: right;
  }
  .prazo-badge .prazo-label {
    display: block;
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1px;
  }

  /* ── CHECK BUTTON ── */
  .check-btn {
    width: 22px; height: 22px;
    border-radius: 50%;
    border: 2px solid var(--border2);
    background: transparent;
    cursor: pointer;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.18s;
    padding: 0;
    outline: none;
  }
  .check-btn:hover { border-color: var(--green); }
  .check-btn svg { display: none; width: 12px; height: 12px; }
  .check-btn.checked {
    background: var(--green);
    border-color: var(--green);
  }
  .check-btn.checked svg { display: block; }
  .acao-card.done { opacity: 0.55; }
  .acao-card.done .acao-card-text { text-decoration: line-through; color: var(--muted); }

  /* ── COMMENTS ── */
  .comments-section {
    border-top: 1px solid var(--border);
    background: var(--bg);
    padding: 0;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.25s ease, padding 0.25s ease;
  }
  .comments-section.open {
    max-height: 600px;
    padding: 12px 18px 14px;
  }
  .comments-toggle {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    color: var(--muted);
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    font-family: 'Sora', sans-serif;
    margin-top: 6px;
    transition: color 0.15s;
    outline: none;
  }
  .comments-toggle:hover { color: var(--accent); }
  .comments-toggle .ct-icon { font-size: 11px; }
  .comments-toggle .ct-count {
    background: var(--border);
    padding: 1px 5px;
    border-radius: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
  }
  .comments-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 10px; }
  .comment-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 8px 10px;
    font-size: 11.5px;
    color: var(--text);
    line-height: 1.5;
    position: relative;
  }
  .comment-meta {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 4px;
  }
  .comment-author {
    font-size: 10px; font-weight: 600;
    color: var(--accent);
